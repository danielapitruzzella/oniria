<%- include('../partials/header', { pageTitle: 'Esplora' }) %>
<% if (currentUser) { %>
  <%- include('../partials/navbar') %>
<% } %>

<main class="container mx-auto px-4 py-8 max-w-6xl">
  <%- include('../partials/flash') %>

  <!-- Hero (solo se non autenticato / landing) -->
  <% if (!currentUser) { %>
    <div class="text-center py-12 mb-8">
      <h1 class="text-5xl font-bold text-brand-primary mb-3 tracking-tight">Oniria</h1>
      <p class="text-xl text-gray-300 mb-2">L'archivio dei sogni ricorrenti</p>
      <p class="text-gray-500 mb-8 max-w-lg mx-auto text-sm">
        Tieni traccia dei tuoi sogni, scopri simboli ricorrenti e connettiti con la community.
      </p>
      <div class="flex justify-center gap-3">
        <a href="/auth/registra" class="btn-primary px-6 py-2.5">Registrati</a>
        <a href="/auth/login" class="btn-secondary-dark px-6 py-2.5">Accedi</a>
      </div>
    </div>
  <% } else { %>
    <h1 class="text-2xl font-bold text-white mb-6">Esplora la community</h1>
  <% } %>

  <div class="grid lg:grid-cols-3 gap-8">

    <!-- Colonna principale: filtri + sogni pubblici -->
    <div class="lg:col-span-2">

      <!-- Form filtri -->
      <details class="rounded-xl border border-night-border mb-5 overflow-hidden" id="filtri-panel"
        <%- haFiltri ? 'open' : '' %>>
        <summary class="px-5 py-3 cursor-pointer text-sm font-medium text-gray-300 flex items-center justify-between select-none"
          style="background-color: var(--color-night-surface);">
          <span>Filtra sogni</span>
          <span class="text-gray-500 text-xs"><%- haFiltri ? '▲ filtri attivi' : '▼' %></span>
        </summary>
        <div class="px-5 pb-5 pt-4 border-t border-night-border" style="background-color: var(--color-night-surface);">
          <form method="GET" action="/esplora" class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="form-filtri">

            <div>
              <label class="form-label" for="f-q">Parola chiave</label>
              <input type="text" id="f-q" name="q" class="form-input"
                value="<%= filtri.parola || '' %>" placeholder="Cerca nel titolo o descrizione...">
            </div>

            <div>
              <label class="form-label" for="f-tag">Tag / Simbolo</label>
              <select id="f-tag" name="tag" class="form-input">
                <option value="">— Tutti i tag —</option>
                <% tagDisponibili.forEach(function(t) { %>
                  <option value="<%= t.nome %>" <%= filtri.tag === t.nome ? 'selected' : '' %>><%= t.nome %></option>
                <% }); %>
              </select>
            </div>

            <div>
              <label class="form-label" for="f-emozione">Emozione</label>
              <select id="f-emozione" name="emozione" class="form-input">
                <option value="">— Tutte le emozioni —</option>
                <% emozioniDisponibili.forEach(function(e) { %>
                  <option value="<%= e.nome %>" <%= filtri.emozione === e.nome ? 'selected' : '' %>><%= e.nome %></option>
                <% }); %>
              </select>
            </div>

            <div class="grid grid-cols-2 gap-2">
              <div>
                <label class="form-label" for="f-intensita-min">Intensità min</label>
                <select id="f-intensita-min" name="intensita_min" class="form-input">
                  <option value="">—</option>
                  <% [1,2,3,4,5].forEach(function(v) { %>
                    <option value="<%= v %>" <%= filtri.intensitaMin === v ? 'selected' : '' %>><%= v %></option>
                  <% }); %>
                </select>
              </div>
              <div>
                <label class="form-label" for="f-intensita-max">Intensità max</label>
                <select id="f-intensita-max" name="intensita_max" class="form-input">
                  <option value="">—</option>
                  <% [1,2,3,4,5].forEach(function(v) { %>
                    <option value="<%= v %>" <%= filtri.intensitaMax === v ? 'selected' : '' %>><%= v %></option>
                  <% }); %>
                </select>
              </div>
            </div>

            <div class="flex items-end gap-2 col-span-1 sm:col-span-2">
              <button type="submit" class="btn-primary">Filtra</button>
              <a href="/esplora" class="btn-secondary">Azzera</a>
            </div>
          </form>
        </div>
      </details>

      <!-- Intestazione risultati -->
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-base font-semibold text-gray-200">
          <% if (haFiltri) { %>
            Risultati filtrati
            <span class="text-gray-500 font-normal text-sm">(<%= sogniPubblici.length %> trovati)</span>
          <% } else { %>
            Sogni recenti della community
            <span class="text-gray-500 font-normal text-sm">(<%= totale %> totali)</span>
          <% } %>
        </h2>
        <% if (haFiltri) { %>
          <a href="/esplora" class="text-xs text-brand-primary hover:underline">Azzera filtri</a>
        <% } %>
      </div>

      <!-- Lista sogni pubblici -->
      <% if (sogniPubblici.length === 0) { %>
        <div class="text-center py-16 text-gray-500">
          <p class="text-4xl mb-3">☁</p>
          <p class="text-gray-400 mb-2">Nessun sogno trovato con questi filtri.</p>
          <a href="/esplora" class="btn-secondary-dark text-sm mt-3">Azzera filtri</a>
        </div>
      <% } else { %>
        <div class="space-y-4">
          <% sogniPubblici.forEach(function(sogno) { %>
            <article class="bg-white rounded-xl shadow p-5 border border-orange-50 hover:shadow-md transition">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-semibold text-gray-800 text-base"><%= sogno.titolo %></h3>
                <span class="badge-intensita-<%= sogno.intensita %> flex-shrink-0"><%= sogno.intensita %>/5</span>
              </div>
              <p class="text-gray-400 text-xs mb-3">📅 <%= formatDate(sogno.data_sogno) %></p>
              <p class="text-gray-600 text-sm leading-relaxed">
                <%= sogno.descrizione.length > 220 ? sogno.descrizione.substring(0, 220) + '…' : sogno.descrizione %>
              </p>
              <% if (sogno.tag && sogno.tag.length > 0) { %>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <% sogno.tag.forEach(function(t) { %>
                    <a href="/esplora?tag=<%= encodeURIComponent(t.nome) %>" class="tag-chip hover:bg-orange-200 transition">
                      <%= t.nome %>
                    </a>
                  <% }); %>
                </div>
              <% } %>
              <% if (sogno.emozioni && sogno.emozioni.length > 0) { %>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <% sogno.emozioni.forEach(function(e) { %>
                    <a href="/esplora?emozione=<%= encodeURIComponent(e.nome) %>" class="emo-chip hover:bg-yellow-400 transition">
                      <%= e.nome %>
                    </a>
                  <% }); %>
                </div>
              <% } %>
            </article>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Sidebar: emozione settimana + tag della settimana -->
    <aside class="space-y-6">

      <!-- Emozione della settimana -->
      <% if (emozioneComuneSett) { %>
        <div class="highlight-box p-5">
          <p class="text-xs font-medium text-brand-primary uppercase tracking-wide mb-2">Emozione della settimana</p>
          <p class="text-2xl font-bold text-white capitalize"><%= emozioneComuneSett.nome %></p>
          <p class="text-xs text-gray-500 mt-1"><%= emozioneComuneSett.conteggio %> occorrenze negli ultimi 7 giorni</p>
          <a href="/esplora?emozione=<%= encodeURIComponent(emozioneComuneSett.nome) %>"
            class="text-xs text-brand-primary hover:underline mt-2 inline-block">
            Vedi sogni →
          </a>
        </div>
      <% } %>

      <!-- Tag della settimana -->
      <div class="highlight-box p-5">
        <p class="text-xs font-medium text-brand-primary uppercase tracking-wide mb-2">Simboli della settimana</p>
        <% if (tagSettimana.length === 0) { %>
          <p class="text-sm text-gray-400">Nessun simbolo pubblico negli ultimi 7 giorni.</p>
        <% } else { %>
          <div class="flex flex-wrap gap-2">
            <% tagSettimana.forEach(function(t) { %>
              <span class="tag-chip">
                <%= t.nome %>(<%= t.conteggio %>)
              </span>
            <% }); %>
          </div>
          <p class="text-xs text-gray-500 mt-3">I 10 simboli pubblici più ricorrenti degli ultimi 7 giorni.</p>
        <% } %>
      </div>
    </aside>
  </div>
</main>
