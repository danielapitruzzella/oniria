<% if (flashMessages.success && flashMessages.success.length) { %>
  <% flashMessages.success.forEach(function(msg) { %>
    <div class="bg-green-50 border border-green-400 text-green-700 px-4 py-3 rounded mb-2 text-sm flex items-start gap-2">
      <span class="flex-shrink-0">&#10003;</span>
      <span><%= msg %></span>
    </div>
  <% }); %>
<% } %>
<% if (flashMessages.error && flashMessages.error.length) { %>
  <% flashMessages.error.forEach(function(msg) { %>
    <div class="bg-red-50 border border-red-400 text-red-700 px-4 py-3 rounded mb-2 text-sm flex items-start gap-2">
      <span class="flex-shrink-0">&#9888;</span>
      <span><%= msg %></span>
    </div>
  <% }); %>
<% } %>
<% if (flashMessages.info && flashMessages.info.length) { %>
  <% flashMessages.info.forEach(function(msg) { %>
    <div class="bg-blue-50 border border-blue-400 text-blue-700 px-4 py-3 rounded mb-2 text-sm flex items-start gap-2">
      <span class="flex-shrink-0">&#9432;</span>
      <span><%= msg %></span>
    </div>
  <% }); %>
<% } %>
