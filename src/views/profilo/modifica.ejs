<%- include('../partials/header', { pageTitle: 'Il mio profilo' }) %>
<%- include('../partials/navbar') %>

<main class="container mx-auto px-4 py-8 max-w-lg">
  <%- include('../partials/flash') %>

  <h1 class="text-2xl font-bold text-white mb-6">Il mio profilo</h1>

  <div class="bg-white rounded-xl shadow-md p-8 border border-orange-50">
    <form method="POST" action="/profilo/modifica" class="space-y-4">

      <div>
        <label class="form-label" for="nome">Nome</label>
        <input type="text" id="nome" name="nome"
          class="form-input<% if (fieldErrors.nome) { %> border-red-400<% } %>"
          value="<%= typeof formData !== 'undefined' && formData.nome ? formData.nome : '' %>"
          maxlength="100" required>
        <% if (fieldErrors.nome) { %>
          <p class="text-red-500 text-xs mt-1"><%= fieldErrors.nome %></p>
        <% } %>
      </div>

      <div>
        <label class="form-label" for="email">Email</label>
        <input type="email" id="email" name="email"
          class="form-input<% if (fieldErrors.email) { %> border-red-400<% } %>"
          value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
          required>
        <% if (fieldErrors.email) { %>
          <p class="text-red-500 text-xs mt-1"><%= fieldErrors.email %></p>
        <% } %>
      </div>

      <div>
        <label class="form-label" for="bio">Bio <span class="text-gray-400 font-normal">(facoltativa)</span></label>
        <textarea id="bio" name="bio" rows="3"
          class="form-input resize-none<% if (fieldErrors.bio) { %> border-red-400<% } %>"
          maxlength="500"><%= typeof formData !== 'undefined' && formData.bio ? formData.bio : '' %></textarea>
        <% if (fieldErrors.bio) { %>
          <p class="text-red-500 text-xs mt-1"><%= fieldErrors.bio %></p>
        <% } %>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary">Salva modifiche</button>
        <a href="/sogni" class="btn-secondary">Annulla</a>
      </div>
    </form>
  </div>

  <div class="mt-6 bg-white rounded-xl shadow-md p-6 border border-orange-50">
    <h2 class="text-base font-semibold text-gray-700 mb-3">Sicurezza</h2>
    <a href="/auth/cambia-password" class="btn-secondary text-sm">Cambia password</a>
  </div>
</main>

