<%- include('../partials/header', { pageTitle: 'Errore del server' }) %>
<%- include('../partials/navbar') %>

<main class="flex-1 flex items-center justify-center px-4">
  <div class="text-center">
    <p class="text-8xl font-bold mb-4" style="color: rgba(249,115,22,0.15);">500</p>
    <h1 class="text-2xl font-bold text-white mb-2">Errore del server</h1>
    <p class="text-gray-400 mb-4">Qualcosa è andato storto. Riprova tra qualche istante.</p>
    <% if (typeof message !== 'undefined' && message) { %>
      <pre class="text-xs text-left bg-night-surface rounded-lg p-4 max-w-xl mx-auto overflow-auto mb-6 text-gray-300 border border-night-border"><%= message %></pre>
    <% } %>
    <a href="/" class="btn-primary">Torna alla home</a>
  </div>
</main>
