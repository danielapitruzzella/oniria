<%- include('../partials/header', { pageTitle: 'Cambia Password' }) %>
<%- include('../partials/navbar') %>

<main class="container mx-auto px-4 py-8 max-w-md">
  <%- include('../partials/flash') %>

  <div class="bg-white rounded-xl shadow-md p-8">
    <h1 class="text-xl font-bold text-gray-800 mb-6">Cambia password</h1>

    <form method="POST" action="/auth/cambia-password" class="space-y-4">

      <div>
        <label class="form-label" for="password_attuale">Password attuale</label>
        <input type="password" id="password_attuale" name="password_attuale" autocomplete="current-password"
          class="form-input<% if (fieldErrors.password_attuale) { %> border-red-400<% } %>"
          required autofocus>
        <% if (fieldErrors.password_attuale) { %>
          <p class="text-red-500 text-xs mt-1"><%= fieldErrors.password_attuale %></p>
        <% } %>
      </div>

      <div>
        <label class="form-label" for="nuova_password">Nuova password</label>
        <input type="password" id="nuova_password" name="nuova_password" autocomplete="new-password"
          class="form-input<% if (fieldErrors.nuova_password) { %> border-red-400<% } %>"
          minlength="8" required>
        <% if (fieldErrors.nuova_password) { %>
          <p class="text-red-500 text-xs mt-1"><%= fieldErrors.nuova_password %></p>
        <% } %>
      </div>

      <div>
        <label class="form-label" for="conferma_password">Conferma nuova password</label>
        <input type="password" id="conferma_password" name="conferma_password" autocomplete="new-password"
          class="form-input<% if (fieldErrors.conferma_password) { %> border-red-400<% } %>"
          required>
        <% if (fieldErrors.conferma_password) { %>
          <p class="text-red-500 text-xs mt-1"><%= fieldErrors.conferma_password %></p>
        <% } %>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary">Aggiorna password</button>
        <a href="/profilo/modifica" class="btn-secondary">Annulla</a>
      </div>
    </form>
  </div>
</main>

