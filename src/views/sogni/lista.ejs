<%- include('../partials/header', { pageTitle: 'I miei sogni' }) %>
<%- include('../partials/navbar') %>

<main class="container mx-auto px-4 py-8 max-w-5xl">
  <%- include('../partials/flash') %>

  <!-- Header dashboard -->
  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <h1 class="text-2xl font-bold text-white">I miei sogni</h1>
    <div class="flex gap-2">
      <a href="/sogni/nuovo" class="btn-primary">+ Nuovo sogno</a>
      <a href="/sogni/esporta-pdf" class="btn-secondary-dark text-sm">Esporta PDF</a>
    </div>
  </div>

  <!-- Form filtri -->
  <details class="rounded-xl border border-night-border mb-6 overflow-hidden" id="filtri-panel"
    <%- (filtri.tag || filtri.emozione || filtri.parola || filtri.dataInizio || filtri.dataFine || filtri.intensitaMin || filtri.intensitaMax) ? 'open' : '' %>>
    <summary class="px-5 py-3 cursor-pointer text-sm font-medium text-gray-300 flex items-center justify-between select-none"
      style="background-color: var(--color-night-surface);">
      <span>Filtri di ricerca</span>
      <span class="text-gray-500 text-xs">▼</span>
    </summary>
    <div class="px-5 pb-5 pt-4 border-t border-night-border" style="background-color: var(--color-night-surface);">
      <form method="GET" action="/sogni" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4" id="form-filtri">

        <div>
          <label class="form-label" for="f-q">Parola chiave</label>
          <input type="text" id="f-q" name="q" class="form-input"
            value="<%= filtri.parola || '' %>" placeholder="Cerca nel titolo...">
        </div>

        <div>
          <label class="form-label" for="f-tag">Tag</label>
          <select id="f-tag" name="tag" class="form-input">
            <option value="">— Tutti i tag —</option>
            <% tagDisponibili.forEach(function(t) { %>
              <option value="<%= t.nome %>" <%= filtri.tag === t.nome ? 'selected' : '' %>><%= t.nome %></option>
            <% }); %>
          </select>
        </div>

        <div>
          <label class="form-label" for="f-emozione">Emozione</label>
          <select id="f-emozione" name="emozione" class="form-input">
            <option value="">— Tutte le emozioni —</option>
            <% emozioniDisponibili.forEach(function(e) { %>
              <option value="<%= e.nome %>" <%= filtri.emozione === e.nome ? 'selected' : '' %>><%= e.nome %></option>
            <% }); %>
          </select>
        </div>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="form-label" for="f-intensita-min">Int. min</label>
            <select id="f-intensita-min" name="intensita_min" class="form-input">
              <option value="">—</option>
              <% [1,2,3,4,5].forEach(function(v) { %>
                <option value="<%= v %>" <%= filtri.intensitaMin === v ? 'selected' : '' %>><%= v %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="form-label" for="f-intensita-max">Int. max</label>
            <select id="f-intensita-max" name="intensita_max" class="form-input">
              <option value="">—</option>
              <% [1,2,3,4,5].forEach(function(v) { %>
                <option value="<%= v %>" <%= filtri.intensitaMax === v ? 'selected' : '' %>><%= v %></option>
              <% }); %>
            </select>
          </div>
        </div>

        <div>
          <label class="form-label" for="f-da">Data da</label>
          <input type="date" id="f-da" name="da" class="form-input"
            value="<%= filtri.dataInizio || '' %>">
        </div>

        <div>
          <label class="form-label" for="f-a">Data a</label>
          <input type="date" id="f-a" name="a" class="form-input"
            value="<%= filtri.dataFine || '' %>">
        </div>

        <div class="flex items-end gap-2 col-span-1 sm:col-span-2">
          <button type="submit" class="btn-primary">Filtra</button>
          <a href="/sogni" class="btn-secondary">Azzera</a>
        </div>
      </form>
    </div>
  </details>

  <!-- Lista sogni -->
  <% if (sogni.length === 0) { %>
    <div class="text-center py-20 text-gray-500">
      <p class="text-5xl mb-4">☁</p>
      <p class="text-lg font-medium text-gray-300 mb-2">Nessun sogno trovato</p>
      <% if (filtri.tag || filtri.emozione || filtri.parola || filtri.dataInizio || filtri.dataFine || filtri.intensitaMin || filtri.intensitaMax) { %>
        <p class="text-sm mb-4">Prova a modificare i filtri</p>
        <a href="/sogni" class="btn-secondary-dark text-sm">Azzera filtri</a>
      <% } else { %>
        <p class="text-sm mb-4">Registra il tuo primo sogno</p>
        <a href="/sogni/nuovo" class="btn-primary">+ Nuovo sogno</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% sogni.forEach(function(sogno) { %>
        <article class="bg-white rounded-xl shadow hover:shadow-lg transition p-5 flex flex-col border border-orange-50">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-semibold text-gray-800 text-sm leading-snug">
              <a href="/sogni/<%= sogno.id %>" class="hover:text-brand-primary transition">
                <%= sogno.titolo %>
              </a>
            </h3>
            <span class="badge-intensita-<%= sogno.intensita %> flex-shrink-0"><%= sogno.intensita %>/5</span>
          </div>

          <p class="text-gray-400 text-xs mb-3"><%= formatDate(sogno.data_sogno) %></p>

          <p class="text-gray-600 text-sm line-clamp-3 flex-1">
            <%= sogno.descrizione.length > 120 ? sogno.descrizione.substring(0, 120) + '…' : sogno.descrizione %>
          </p>

          <div class="mt-3 flex items-center justify-between">
            <% if (sogno.pubblico) { %>
              <span class="text-xs text-green-600 bg-green-50 px-2 py-0.5 rounded-full">Pubblico</span>
            <% } else { %>
              <span class="text-xs text-gray-400 bg-gray-50 px-2 py-0.5 rounded-full">Privato</span>
            <% } %>
            <a href="/sogni/<%= sogno.id %>" class="text-brand-primary text-xs hover:underline">Leggi →</a>
          </div>
        </article>
      <% }); %>
    </div>

    <p class="text-right text-xs text-gray-500 mt-4">
      <%= sogni.length %> <%= sogni.length === 1 ? 'sogno trovato' : 'sogni trovati' %>
    </p>
  <% } %>
</main>
